---
layout: base.njk
title: Browse Tokens
permalink: /browse/index.html
---

<section class="section">
  <nav class="breadcrumbs" aria-label="Breadcrumb">
    <a href="/">Home</a>
    <span>/</span>
    <span>Browse</span>
  </nav>

  <h1>Browse Tokens</h1>
  <p class="section-intro">Browse by borough and token type.</p>

  <div class="card browse-controls">
    <div class="browse-search-group">
      <input
        type="text"
        id="browse-search"
        class="browse-search-input"
        placeholder="Search by ID, title, borough, type, material, or notes..." />
    </div>

    <div class="browse-filter-group" data-filter-group="borough">
      <div class="browse-filter-heading">
        <strong>Borough</strong>
        <button type="button" class="browse-group-action" data-action="all" data-filter="borough">All boroughs</button>
      </div>

      <div class="browse-chip-row">
        {% for item in browseView.filters.boroughs %}
          <button type="button" class="browse-chip is-active" data-filter="borough" data-value="{{ item }}">
            <span>{{ item }}</span>
            <span class="browse-chip-count">0</span>
          </button>
        {% endfor %}
      </div>
    </div>

    <div class="browse-filter-group" data-filter-group="type">
      <div class="browse-filter-heading">
        <strong>Type</strong>
        <button type="button" class="browse-group-action" data-action="all" data-filter="type">All types</button>
      </div>

      <div class="browse-chip-row">
        {% for item in browseView.filters.types %}
          <button type="button" class="browse-chip is-active" data-filter="type" data-value="{{ item }}">
            <span>{{ lookups.type[item] }}</span>
            <span class="browse-chip-count">0</span>
          </button>
        {% endfor %}
      </div>
    </div>

    <div class="browse-summary">
      <strong id="browse-count"></strong>
      <button type="button" id="browse-reset">Reset filters</button>
    </div>
  </div>

  <div id="browse-grid" class="grid-3 browse-grid">
  {% for token in browseView.tokens %}
    <article
      class="card browse-card"
      data-borough="{{ token.borough }}"
      data-types="{{ token.browseTypes | join(' ') }}"
      data-search="{{ token.searchText }}">

      <a class="card-link browse-card-link" href="{{ token.url or '/' }}">
        <div class="browse-card-media">
          {% if token | hasTokenThumb("o") %}
            <img src="{{ token | tokenThumbPath('o') }}" alt="{{ token.displayId }}">
          {% elif token | hasTokenImage("o") %}
            <img src="{{ token | tokenImagePath('o') }}" alt="{{ token.displayId }}">
          {% else %}
            <div class="browse-card-placeholder">No Image</div>
          {% endif %}
        </div>

        <div class="browse-card-body">
          <div class="browse-card-topline">
            <strong class="browse-card-id">{{ token.displayId }}</strong>

            <span class="browse-badge browse-badge-{{ token.status }}">
              {{ token.status | capitalize }}
            </span>
          </div>

          <p class="browse-card-title">{{ token.title }}</p>

          <p class="meta browse-card-meta">
            {{ token.borough }} · {{ lookups.type[token.type] }}
          </p>
        </div>
      </a>
    </article>
  {% endfor %}
</div>
</section>
<script src="/assets/js/browse.js" defer></script>
