---
layout: base.njk
pagination:
  data: collections.officialAll
  size: 1
  alias: token
permalink: "/official/{{ token.displayId | lower }}/index.html"
eleventyComputed:
  title: "{{ token.displayId }} – {{ token.title }}"
---

{#
  Canonical official token page.
  Assumptions:
  - official tokens use canonical schema fields only
  - displayId and title always exist
  - official tokens are never inferred from fallback IDs
#}

{% set tokenId = token.displayId %}
{% set tokenTitle = token.title %}
{% set isUnlisted = false %}

{# Resolve the display label for the owning listed section. #}
{% set sectionLabel = token.sec %}
{% set sectionUrl = "/listed/" ~ token.sec | lower ~ "/" %}
{% set matchedSection = null %}

{% for section in sections %}
  {% if section.sec == token.sec and section.pub %}
    {% set matchedSection = section %}
  {% endif %}
{% endfor %}

{% if matchedSection %}
  {% set sectionLabel = matchedSection.title %}
{% endif %}

{# Build the ordered set of published official tokens in the same section for pager navigation. #}
{% set sectionTokens = [] %}
{% for item in collections.officialAll %}
  {% if item.sec == token.sec and item.pub %}
    {% set sectionTokens = sectionTokens.concat([item]) %}
  {% endif %}
{% endfor %}

{% set prevToken = null %}
{% set nextToken = null %}

{% for item in sectionTokens %}
  {% if item.displayId == token.displayId %}
    {% if loop.index0 > 0 %}
      {% set prevToken = sectionTokens[loop.index0 - 1] %}
    {% endif %}
    {% if loop.index0 < (sectionTokens | length - 1) %}
      {% set nextToken = sectionTokens[loop.index0 + 1] %}
    {% endif %}
  {% endif %}
{% endfor %}

{% set detailView = tokenDetailView.buildTokenDetailView(token, {
  tokenId: tokenId,
  tokenTitle: tokenTitle,
  detailSectionTitle: sectionLabel,
  detailSectionUrl: sectionUrl,
  detailImageDataset: "official",
  detailImageIsOfficial: true,
  detailShowPager: true,
  prevToken: prevToken,
  nextToken: nextToken,
  isUnlisted: isUnlisted,
  lookups: lookups
}) %}

{% include "token-detail.njk" %}
