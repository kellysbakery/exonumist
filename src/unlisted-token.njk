---
layout: base.njk
pagination:
  data: unlisted
  size: 1
  alias: token
permalink: "/unlisted/{{ token.siteId | lower }}/index.html"
eleventyComputed:
  title: "{{ token.siteId }} – {{ token.displayTitle }}"
---
<section class="token-shell">
  <div class="token-hero">
    <div>
      <div class="meta">Home / Unlisted Tokens / {{ token.siteId }}</div>
      <h1>{{ token.displayTitle }}</h1>
      <div class="badges">
        <span class="badge">{{ token.status | lookup(lookups.status) }}</span>
        <span class="badge">{{ token.type | lookup(lookups.type) }}</span>
        <span class="badge">{{ token.mat | lookup(lookups.materials) }}</span>
        <span class="badge">{{ token.form | lookup(lookups.forms) }}</span>
        <span class="badge">{{ token.symbol | lookup(lookups.symbols) }}</span>
      </div>
      <p>{{ token.desc }}</p>
    </div>
    <aside class="facts">
      <h2>Quick Facts</h2>
      <dl>
        <div class="facts-row"><dt>Site ID</dt><dd>{{ token.siteId }}</dd></div>
        <div class="facts-row"><dt>Status</dt><dd>{{ token.status | lookup(lookups.status) }}</dd></div>
        <div class="facts-row"><dt>Type</dt><dd>{{ token.type | lookup(lookups.type) }}</dd></div>
        {% if token.relCatalog and token.relCatalog.length %}<div class="facts-row"><dt>Related A/C</dt><dd>{{ token.relCatalog | join(", ") }}</dd></div>{% endif %}
      </dl>
    </aside>
  </div>

  <div class="token-images">
    <figure>
      {% if token | hasFallbackImage("unlisted", "o") %}
      <img src="{{ token | fallbackImagePath('unlisted', 'o') }}" alt="{{ token.siteId }} obverse" style="width:100%;max-width:460px;aspect-ratio:1/1;object-fit:contain;display:block;margin:0 auto 12px;" />
      {% else %}
      <div class="placeholder">Expected image:<br>{{ token | fallbackImagePath("unlisted", "o") }}</div>
      {% endif %}
      <figcaption>Obverse</figcaption>
    </figure>
    <figure>
      {% if token | hasFallbackImage("unlisted", "r") %}
      <img src="{{ token | fallbackImagePath('unlisted', 'r') }}" alt="{{ token.siteId }} reverse" style="width:100%;max-width:460px;aspect-ratio:1/1;object-fit:contain;display:block;margin:0 auto 12px;" />
      {% else %}
      <div class="placeholder">Expected image:<br>{{ token | fallbackImagePath("unlisted", "r") }}</div>
      {% endif %}
      <figcaption>Reverse</figcaption>
    </figure>
  </div>

</section>
