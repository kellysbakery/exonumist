---
layout: base.njk
pagination:
  data: unlistedAll
  size: 1
  alias: token
permalink: "/unlisted/{{ token.displayId | lower }}/index.html"
eleventyComputed:
  title: "{{ token.displayId }} – {{ token.title }}"
---

{% set tokenId = token.displayId %}
{% set tokenTitle = token.title %}
{% set isUnlisted = true %}

{% set detailSectionTitle = "Unlisted" %}
{% set detailSectionUrl = "/unlisted/" %}

{% if token.groups and ("counterfeit" in token.groups) %}
  {% set detailSectionTitle = "Counterfeit" %}
  {% set detailSectionUrl = "/groups/counterfeit/" %}
  {% set detailImageDataset = "counterfeit" %}
{% elseif token.groups and ("errors" in token.groups) %}
  {% set detailSectionTitle = "Oddities & Errors" %}
  {% set detailSectionUrl = "/groups/errors/" %}
  {% set detailImageDataset = "oddities" %}
{% else %}
  {% set detailImageDataset = "unlisted" %}
{% endif %}

{% set detailImageIsOfficial = false %}
{% set detailShowPager = false %}

{% set detailView = tokenDetailView.buildTokenDetailView(token, {
  tokenId: tokenId,
  tokenTitle: tokenTitle,
  detailSectionTitle: detailSectionTitle,
  detailSectionUrl: detailSectionUrl,
  detailImageDataset: detailImageDataset,
  detailImageIsOfficial: detailImageIsOfficial,
  detailShowPager: detailShowPager,
  isUnlisted: isUnlisted,
  lookups: lookups
}) %}

{% include "token-detail.njk" %}
