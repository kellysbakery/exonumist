---
layout: base.njk
pagination:
  data: unofficialAll
  size: 1
  alias: token
permalink: "/unlisted/{{ token.displayId | lower }}/index.html"
eleventyComputed:
  title: "{{ token.displayId }} – {{ token.title }}"
---

{% set unlistedSection = tokenDetailView.buildUnlistedSection(token) %}
{% set detailSectionTitle = unlistedSection.title %}
{% set detailSectionUrl = unlistedSection.url %}

{% set detailView = tokenDetailView.buildTokenDetailView(token, {
  tokenId: token.displayId,
  tokenTitle: token.title,
  detailSectionTitle: detailSectionTitle,
  detailSectionUrl: detailSectionUrl,
  detailShowPager: false,
  isUnlisted: true,
  lookups: lookups
}) %}

{% include "token-detail.njk" %}
