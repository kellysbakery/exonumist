---
layout: layouts/base.njk
pagination:
  data: collections.officialAll
  size: 1
  alias: token
permalink: "/official/{{ token.displayId | lower }}/index.html"
eleventyComputed:
  title: "{{ token.displayId }} – {{ token.title }}"
---
<section class="token-shell">
  <div class="token-hero">
    <div>
      <div class="meta">Home / Official NYC Tokens / Section {{ token.sec }} / {{ token.displayId }}</div>
      <h1>{{ token.displayId }}</h1>
      <p class="meta">{{ token.title }} · Section {{ token.sec }}</p>
      <div class="badges">
        <span class="badge">{{ token.status | lookup(lookups.status) }}</span>
        <span class="badge">{{ token.type | lookup(lookups.type) }}</span>
        <span class="badge">{{ token.mat | lookup(lookups.materials) }}</span>
        <span class="badge">{{ token.form | lookup(lookups.forms) }}</span>
        <span class="badge">{{ token.symbol | lookup(lookups.symbols) }}</span>
        <span class="badge">{{ token.size }} mm</span>
      </div>
      <p>{{ token.desc }}{% if token.notes %} {{ token.notes }}{% endif %}</p>
    </div>
    <aside class="facts">
      <h2>Quick Facts</h2>
      <dl>
        <div class="facts-row"><dt>Catalog ID</dt><dd>{{ token.displayId }}</dd></div>
        <div class="facts-row"><dt>Section</dt><dd>{{ token.sec }}</dd></div>
        <div class="facts-row"><dt>Code</dt><dd>{{ token.code }}</dd></div>
        {% if token.var %}<div class="facts-row"><dt>Minor Variety</dt><dd>{{ token.var }}</dd></div>{% endif %}
        <div class="facts-row"><dt>Catalog Status</dt><dd>{{ token.status | lookup(lookups.status) }}</dd></div>
        <div class="facts-row"><dt>Type</dt><dd>{{ token.type | lookup(lookups.type) }}</dd></div>
        <div class="facts-row"><dt>A/C Value</dt><dd>${{ token.val }}</dd></div>
      </dl>
    </aside>
  </div>

  <div class="token-images">
    <figure>
      {% if token | hasOfficialImage("o") %}
      <img src="{{ token | officialImagePath('o') }}" alt="{{ token.displayId }} obverse" style="width:100%;max-width:460px;aspect-ratio:1/1;object-fit:contain;display:block;margin:0 auto 12px;" />
      {% else %}
      <div class="placeholder">Expected image:<br>{{ token | officialImagePath("o") }}</div>
      {% endif %}
      <figcaption>Obverse</figcaption>
    </figure>
    <figure>
      {% if token | hasOfficialImage("r") %}
      <img src="{{ token | officialImagePath('r') }}" alt="{{ token.displayId }} reverse" style="width:100%;max-width:460px;aspect-ratio:1/1;object-fit:contain;display:block;margin:0 auto 12px;" />
      {% else %}
      <div class="placeholder">Expected image:<br>{{ token | officialImagePath("r") }}</div>
      {% endif %}
      <figcaption>Reverse</figcaption>
    </figure>
  </div>

  <section class="section">
    <h2>Catalog Details</h2>
    <div class="facts">
      <dl>
        <div class="facts-row"><dt>Obverse</dt><dd>{{ token.obv }}</dd></div>
        <div class="facts-row"><dt>Reverse</dt><dd>{{ token.rev }}</dd></div>
        <div class="facts-row"><dt>Description</dt><dd>{{ token.desc }}</dd></div>
        {% if token.notes %}<div class="facts-row"><dt>Notes</dt><dd>{{ token.notes }}</dd></div>{% endif %}
        {% if token.market %}<div class="facts-row"><dt>Market Note</dt><dd>{{ token.market }}</dd></div>{% endif %}
      </dl>
    </div>
  </section>
</section>
