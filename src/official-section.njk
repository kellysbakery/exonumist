---
layout: base.njk
pagination:
  data: sections
  size: 1
  alias: section
permalink: "/listed/{{ section.sec }}/index.html"
eleventyComputed:
  title: "{{ section.title }} – Listed Tokens"
---
{% if section.pub %}
<section class="section">
  <h1>{{ section.title }}</h1>
  <p class="section-intro">Listed {{ section.borough }} transportation tokens from the {{ site.catalog.shortName }}.</p>
  <div class="grid-3">
    {% for token in collections.officialAll %}
      {% if token.sec == section.sec and token.pub %}
      <a class="card-link" href="/official/{{ token.displayId | lower }}/">
        <article class="card">
          <span class="eyebrow">{{ token.displayId }}</span>
          <strong>{{ token.title }}</strong>
          <p>{{ token.desc }}{% if token.notes %} {{ token.notes }}{% endif %}</p>
        </article>
      </a>
      {% endif %}
    {% endfor %}
  </div>
</section>
{% endif %}