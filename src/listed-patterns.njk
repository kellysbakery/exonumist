---
layout: base.njk
title: Patterns
permalink: /listed/patterns/index.html
---
<section class="section">
  <h1>Patterns</h1>
  <p class="section-intro">Listed pattern issues included in the {{ site.catalog.name }}.</p>
  <div class="grid-3">
    {% for token in specialIssues %}
      {% if token.pub and token.series == "pattern" %}
      <a class="card-link" href="/special-issues/">
        <article class="card">
          <span class="eyebrow">{{ token.displayId }}</span>
          <strong>{{ token.title }}</strong>
          <p>{{ token.desc }}</p>
        </article>
      </a>
      {% endif %}
    {% endfor %}
  </div>
</section>