---
layout: base.njk
title: Keith's NYC Transit Token Collection
---
<section class="hero hero-home hero-home-wide">
  <div class="hero-home-grid">
    <div class="hero-home-main">
      <div class="hero-branding">
        <img
          class="hero-logo"
          src="/images/exonumist-banner.png"
          alt="Exonumist.com token logo banner" />
      </div>

      <h1>Keith&rsquo;s NYC Transit Token Collection</h1>

      <div class="hero-copy">
        <p>
          Welcome to my online token collection, with a special focus on New York City transportation
          exonumia. I collect tokens for the history they preserve, the stories they tell, and the
          connection they offer to everyday life in earlier eras.
        </p>

        <p class="note">
          In addition to Transit pieces, my collection includes Arcade, Hard Times, Civil War, Merchant,
          and Miscellaneous tokens. Listed material follows the {{ site.catalog.name }} where applicable.
        </p>
      </div>

      <div class="hero-actions">
        <a href="/listed/" class="btn primary">Browse Listed Tokens</a>
        <a href="/unlisted/" class="btn">Explore Unlisted Tokens</a>
      </div>
    </div>

  {% for group in groups %}
    {% if group.featured %}
    <aside class="hero-feature">
      <a class="card-link" href="{{ group.url }}">
        <div class="hero-feature-card hero-feature-card-minimal">
          <img src="{{ group.heroImage }}" alt="{{ group.title }}" />
          <div class="hero-feature-text">
            <strong>{{ group.heroLabel }}</strong>
            <p><strong>{{ group.title }}</strong></p>
            <p>{{ group.heroText }}</p>
          </div>
        </div>
      </a>
    </aside>
  {% endif %}
{% endfor %}
  </div>
</section>

<section class="section">
  <h2>Listed Tokens</h2>
  <p class="section-intro">
    Browse listed New York City transportation-related tokens by borough and listed special groups.
  </p>

  <div class="grid-4">
    {% for group in groups | sort(attribute="order") %}
      {% if group.section == "listed" %}
      <a class="card-link" href="{{ group.url }}">
        <article class="card">
          <strong>{{ group.title }}</strong>
          <p>{{ group.description }}</p>
        </article>
      </a>
      {% endif %}
    {% endfor %}
  </div>
</section>

<section class="section">
  <h2>Unlisted Tokens</h2>
  <p class="section-intro">
    New York City transportation-related tokens not presently included in the {{ site.catalog.name }}.
  </p>

  <div class="grid-3">
    {% for group in groups | sort(attribute="order") %}
      {% if group.section == "unlisted" %}
      <a class="card-link" href="{{ group.url }}">
        <article class="card">
          <strong>{{ group.title }}</strong>
          <p>{{ group.description }}</p>
        </article>
      </a>
      {% endif %}
    {% endfor %}
  </div>
</section>

<section class="section">
  <h2>Spotlight</h2>
  <p class="section-intro">
    Featured collecting areas and historically significant token groups.
  </p>

  <div class="grid-3">
    {% for group in groups | sort(attribute="order") %}
      {% if group.section == "spotlight" %}
      <a class="card-link" href="{{ group.url }}">
        <article class="card">
          <strong>{{ group.title }}</strong>
          <p>{{ group.description }}</p>
        </article>
      </a>
      {% endif %}
    {% endfor %}
  </div>
</section>

<section class="section">
  <h2>Resources</h2>
  <div class="grid-3">
    {% for resource in resources | sort(attribute="order") %}
      {% if resource.pub %}
      <a class="card-link" href="{{ resource.urlRef | resolveUrlRef(site) }}">
        <article class="resource-card">
          <strong>{{ resource.title }}</strong>
          <p>{{ resource.text }}</p>
        </article>
      </a>
      {% endif %}
    {% endfor %}
  </div>
</section>
