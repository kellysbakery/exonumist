---
layout: layouts/base.njk
title: Exonumist
---
<section class="hero">
  <div class="hero-grid">
    <div>
      <h1>New York City Transportation Tokens, Cataloged and Beyond</h1>
      <p>Exonumist is a digital reference and showcase focused on New York City transportation tokens, varieties, unlisted pieces, oddities, patterns, club tour issues, and related transit exonumia.</p>
      <p class="note">Official listings on this site follow the {{ site.catalog.name }} where applicable.</p>
      <div class="hero-actions">
        <a href="/official/" class="btn primary">{{ site.labels.official }}</a>
        <a href="/unlisted/" class="btn">{{ site.labels.unlisted }}</a>
      </div>
    </div>
    <div class="hero-side">
      <div class="mini-card"><strong>Official Listings</strong><br/>Standard NYC catalog entries arranged by borough and section.</div>
      <div class="mini-card"><strong>Unlisted Tokens</strong><br/>Real New York City tokens that remain outside the printed listings.</div>
      <div class="mini-card"><strong>Oddities &amp; Errors</strong><br/>Mispunched, double struck, exception, and other unusual pieces.</div>
      <div class="mini-card"><strong>Patterns &amp; Special Issues</strong><br/>Patterns, club tour tokens, and other non-circulating material.</div>
    </div>
  </div>
</section>

<section class="section">
  <h2>{{ site.labels.official }}</h2>
  <p class="section-intro">Browse standard A/C-listed New York City tokens by borough and section.</p>
  <div class="grid-5">
    {% for section in sections | sort(attribute="order") %}
      {% if section.pub %}
      <article class="card">
        <span class="eyebrow">Section {{ section.sec }}</span>
        <strong>{{ section.title }}</strong>
        <p>{{ section.borough }} listings from the {{ site.catalog.shortName }}.</p>
        <a class="cta" href="/official/{{ section.sec }}/">Browse {{ section.title }} →</a>
      </article>
      {% endif %}
    {% endfor %}
  </div>
</section>

<section class="section">
  <h2>{{ site.labels.unlisted }}</h2>
  <p class="section-intro">New York City transportation-related tokens and pieces not presently included in the Atwood-Coffee Catalog.</p>
  <div class="grid-3">
    {% for token in unlisted %}
      {% if token.pub and token.home %}
      <article class="card">
        <span class="eyebrow">{{ token.siteId }}</span>
        <strong>{{ token.displayTitle }}</strong>
        <p>{{ token.desc }}</p>
        <a class="cta" href="/unlisted/{{ token.siteId | lower }}/">View token →</a>
      </article>
      {% endif %}
    {% endfor %}
  </div>
</section>

<section class="section">
  <div class="grid-3">
    {% for resource in resources | sort(attribute="order") %}
      {% if resource.pub %}
      <article class="resource-card">
        <strong><a href="{{ resource.urlRef | resolveUrlRef(site) }}">{{ resource.title }}</a></strong>
        <p>{{ resource.text }}</p>
      </article>
      {% endif %}
    {% endfor %}
  </div>
</section>
