---
layout: base.njk
title: Keith's NYC Transit Token Collection
description: Collector-focused reference for New York City transportation tokens, unlisted discoveries, patterns, counterfeits, and related exonumia.
---

<section class="hero hero-home hero-home-wide">
  <div class="hero-home-grid">
    <div class="hero-home-main">
      <div class="hero-branding">
        <img
          class="hero-logo"
          src="/assets/images/site/exonumist-banner.png"
          alt="Exonumist.com token logo banner" />
      </div>

      <h1>Keith&rsquo;s NYC Transit Token Collection</h1>

      <div class="hero-copy">
        <p>
          Welcome to my online token collection, with a special focus on New York City transportation
          exonumia. I collect tokens for the history they preserve, the stories they tell, and the
          connection they offer to everyday life in earlier eras.
        </p>

        <p class="note">
          Start with the Collection areas below, or use Browse to search across listed, unlisted,
          specialty, oddity, counterfeit, and related material.
        </p>
      </div>

      <div class="hero-actions">
        <a href="/collection/" class="btn primary">Enter Collection</a>
        <a href="/browse/" class="btn">Browse All Tokens</a>
      </div>
    </div>

    {% for group in groups %}
      {% if group.featured %}
        <aside class="hero-feature">
          <a class="card-link" href="{{ group.url }}">
            <div class="hero-feature-card hero-feature-card-minimal">
              <div class="hero-feature-text">
                <strong>{{ group.heroLabel }}</strong>
                <p><strong>{{ group.title }}</strong></p>
              </div>

              {% if group.heroImageForm == "R" %}
                <div class="token-list-card-media-frame token-list-card-media-frame--round">
                  <img
                    class="token-list-card-image"
                    src="{{ group.heroImage }}"
                    alt="{{ group.title }}" />
                </div>
              {% elif group.heroImageForm == "Oc" %}
                <div class="token-list-card-media-frame token-list-card-media-frame--octagon">
                  <img
                    class="token-list-card-image"
                    src="{{ group.heroImage }}"
                    alt="{{ group.title }}" />
                </div>
              {% else %}
                <img
                  src="{{ group.heroImage }}"
                  alt="{{ group.title }}" />
              {% endif %}

              <div class="hero-feature-text">
                <p>{{ group.heroText }}</p>
              </div>
            </div>
          </a>
        </aside>
      {% endif %}
    {% endfor %}
  </div>
</section>

<section class="section">
  <h2>Collection</h2>

  <p class="section-intro">
    Browse by collecting area. Listed and unlisted status stays inside each area as metadata and filters.
  </p>

  <div class="home-section-grid">
    {% for area in collectionAreas %}
      <a class="card-link" href="/collection/{{ area.slug }}/">
        <article class="card home-section-card">
          <div class="home-section-card-layout">
            <div class="home-section-card-body">
              <strong class="home-section-card-title">{{ area.title }}</strong>
              <p class="home-section-card-desc">{{ area.description }}</p>
            </div>

            {% if area.cardImage %}
              <div class="home-section-card-media">
                {% if area.cardImageForm == "R" %}
                  <div class="token-list-card-media-frame token-list-card-media-frame--round">
                    <img
                      class="token-list-card-image"
                      src="{{ area.cardImage }}"
                      alt="{{ area.title }}" />
                  </div>
                {% elif area.cardImageForm == "Oc" %}
                  <div class="token-list-card-media-frame token-list-card-media-frame--octagon">
                    <img
                      class="token-list-card-image"
                      src="{{ area.cardImage }}"
                      alt="{{ area.title }}" />
                  </div>
                {% else %}
                  <img
                    class="home-section-card-image"
                    src="{{ area.cardImage }}"
                    alt="{{ area.title }}" />
                {% endif %}
              </div>
            {% endif %}
          </div>
        </article>
      </a>
    {% endfor %}
  </div>
</section>

<section class="section">
  <h2>Spotlight</h2>

  <p class="section-intro">
    Curated collecting areas, favorite pieces, and historically significant groups from the collection.
  </p>

  <div class="home-section-grid">
    {% for group in groups | sort(attribute="order") %}
      {% if group.section == "spotlight" or group.featured %}
        {% set spotlightImage = group.cardImage or group.heroImage %}
        {% set spotlightImageForm = group.cardImageForm or group.heroImageForm %}

        <a class="card-link" href="{{ group.url }}">
          <article class="card home-section-card">
            <div class="home-section-card-layout">
              <div class="home-section-card-body">
                <strong class="home-section-card-title">{{ group.title }}</strong>
                <p class="home-section-card-desc">{{ group.description }}</p>
              </div>

              {% if spotlightImage %}
                <div class="home-section-card-media">
                  {% if spotlightImageForm == "R" %}
                    <div class="token-list-card-media-frame token-list-card-media-frame--round">
                      <img
                        class="token-list-card-image"
                        src="{{ spotlightImage }}"
                        alt="{{ group.title }}" />
                    </div>
                  {% elif spotlightImageForm == "Oc" %}
                    <div class="token-list-card-media-frame token-list-card-media-frame--octagon">
                      <img
                        class="token-list-card-image"
                        src="{{ spotlightImage }}"
                        alt="{{ group.title }}" />
                    </div>
                  {% else %}
                    <img
                      class="home-section-card-image"
                      src="{{ spotlightImage }}"
                      alt="{{ group.title }}" />
                  {% endif %}
                </div>
              {% endif %}
            </div>
          </article>
        </a>
      {% endif %}
    {% endfor %}
  </div>
</section>
