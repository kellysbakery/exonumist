---
layout: base.njk
title: Keith's NYC Transit Token Collection
description: Collector-focused reference for New York City transportation tokens, unlisted discoveries, patterns, counterfeits, and related exonumia.
---

<section class="hero hero-home hero-home-wide">
  <div class="hero-home-grid">
    <div class="hero-home-main">
      <div class="hero-branding">
        <img
          class="hero-logo"
          src="/assets/images/site/exonumist-banner.png"
          alt="Exonumist.com token logo banner" />
      </div>

      <h1>Keith&rsquo;s NYC Transit Token Collection</h1>

      <div class="hero-copy">
        <p>
          Welcome to my online token collection, with a special focus on New York City transportation
          exonumia. I collect tokens for the history they preserve, the stories they tell, and the
          connection they offer to everyday life in earlier eras.
        </p>

        <p class="note">
          In addition to Transit pieces, my collection includes Arcade, Hard Times, Civil War, Merchant,
          and Miscellaneous tokens. Listed material follows the {{ site.catalog.name }} where applicable.
        </p>
      </div>

      <div class="hero-actions">
        <a href="/browse/" class="btn primary">Browse All Tokens</a>
        <a href="/listed/" class="btn">Listed Catalog</a>
        <a href="/unlisted/" class="btn">Unlisted Items</a>
      </div>
    </div>

    {% for group in groups %}
      {% if group.featured %}
        <aside class="hero-feature">
          <a class="card-link" href="{{ group.url }}">
            <div class="hero-feature-card hero-feature-card-minimal">
              <div class="hero-feature-text">
                <strong>{{ group.heroLabel }}</strong>
                <p><strong>{{ group.title }}</strong></p>
              </div>

              <img src="{{ group.heroImage }}" alt="{{ group.title }}" />

              <div class="hero-feature-text">
                <p>{{ group.heroText }}</p>
              </div>
            </div>
          </a>
        </aside>
      {% endif %}
    {% endfor %}
  </div>
</section>

{% for siteSection in siteSections %}
  {% if siteSection.pub != false %}
    <section class="section">
      <h2>{{ siteSection.title }}</h2>

      {% if siteSection.intro %}
        <p class="section-intro">{{ siteSection.intro }}</p>
      {% endif %}

      <div class="home-section-grid">
        {% for group in groups | sort(attribute="order") %}
          {% if group.section == siteSection.key %}
            <a class="card-link" href="{{ group.url }}">
              <article class="card home-section-card">
                <div class="home-section-card-layout">
                  <div class="home-section-card-body">
                    <strong class="home-section-card-title">{{ group.title }}</strong>
                    <p class="home-section-card-desc">{{ group.description }}</p>
                  </div>

                  {% if group.cardImage %}
                    <div class="home-section-card-media">
                      {% if group.cardImageForm == "R" %}
                        <div class="token-list-card-media-frame token-list-card-media-frame--round">
                          <img
                            class="token-list-card-image"
                            src="{{ group.cardImage }}"
                            alt="{{ group.title }}" />
                        </div>
                      {% elif group.cardImageForm == "Oc" %}
                        <div class="token-list-card-media-frame token-list-card-media-frame--octagon">
                          <img
                            class="token-list-card-image"
                            src="{{ group.cardImage }}"
                            alt="{{ group.title }}" />
                        </div>
                      {% else %}
                        <img
                          class="home-section-card-image"
                          src="{{ group.cardImage }}"
                          alt="{{ group.title }}" />
                      {% endif %}
                    </div>
                  {% endif %}
                </div>
              </article>
            </a>
          {% endif %}
        {% endfor %}
      </div>
    </section>
  {% endif %}
{% endfor %}
