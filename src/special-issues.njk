---
layout: base.njk
title: Patterns & Special Issues
permalink: /special-issues/index.html
---
<section class="section">
  <h1>{{ site.labels.special }}</h1>
  <div class="grid-3">
    {% for token in specialIssues %}
      {% if token.pub %}
      <article class="card">
        <span class="eyebrow">{{ token.displayId }}</span>
        <strong>{{ token.title }}</strong>
        <p>{{ token.desc }}</p>
      </article>
      {% endif %}
    {% endfor %}
  </div>
</section>
