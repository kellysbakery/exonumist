---
layout: base.njk
title: Collection
description: Browse the Exonumist collection by collecting area.
permalink: /collection/index.html
---

<section class="section">
  <nav class="breadcrumb" aria-label="Breadcrumb">
    <a href="/">Home</a>
    <span>/</span>
    <span>Collection</span>
  </nav>

  <h1>Collection</h1>

  <p class="section-intro">
    Browse the collection by collecting area. Listed and unlisted status remains metadata within each area.
  </p>

  <div class="home-section-grid">
    {% for area in collectionAreas %}
      <a class="card-link" href="/collection/{{ area.slug }}/">
        <article class="card home-section-card">
          <div class="home-section-card-layout">
            <div class="home-section-card-body">
              <strong class="home-section-card-title">{{ area.title }}</strong>
              <p class="home-section-card-desc">{{ area.description }}</p>
            </div>

            {% if area.cardImage %}
              <div class="home-section-card-media">
                {% if area.cardImageForm == "R" %}
                  <div class="token-list-card-media-frame token-list-card-media-frame--round">
                    <img
                      class="token-list-card-image"
                      src="{{ area.cardImage }}"
                      alt="{{ area.title }}" />
                  </div>
                {% elif area.cardImageForm == "Oc" %}
                  <div class="token-list-card-media-frame token-list-card-media-frame--octagon">
                    <img
                      class="token-list-card-image"
                      src="{{ area.cardImage }}"
                      alt="{{ area.title }}" />
                  </div>
                {% else %}
                  <img
                    class="home-section-card-image"
                    src="{{ area.cardImage }}"
                    alt="{{ area.title }}" />
                {% endif %}
              </div>
            {% endif %}
          </div>
        </article>
      </a>
    {% endfor %}
  </div>
</section>
