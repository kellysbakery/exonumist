{% set detailSectionTitle = detailSectionTitle or "Tokens" %}
{% set detailSectionUrl = detailSectionUrl or "/" %}
{% set detailView = detailView or tokenDetailView or display %}

<section class="token-shell">
  <div class="meta breadcrumb">
    {% for crumb in detailView.breadcrumbItems %}
      {% if crumb.url %}
        <a href="{{ crumb.url }}">{{ crumb.label }}</a>
        {% if not loop.last %}<span>/</span>{% endif %}
      {% else %}
        <span aria-current="page">{{ crumb.label }}</span>
      {% endif %}
    {% endfor %}
  </div>

  <h1>{{ detailView.tokenId }}</h1>

  <p class="token-subtitle">{{ detailView.tokenTitle }}</p>

  {% if detailView.metaParts and detailView.metaParts.length %}
    <p class="token-meta-line">{{ detailView.metaParts | join(" · ") }}</p>
  {% endif %}

  {% if detailView.badges and detailView.badges.length %}
    <div class="badges">
      {% for badge in detailView.badges %}
        <span class="badge">{{ badge }}</span>
      {% endfor %}
    </div>
  {% endif %}

  {% if token.desc %}
    <div class="token-summary">
      <p>{{ token.desc }}</p>
    </div>
  {% endif %}

  <div class="token-images">
    <figure class="token-image-card">
      {% if token | hasTokenImage("o") %}
        <img
          class="token-image"
          src="{{ token | tokenImagePath('o') }}"
          alt="{{ detailView.tokenId }} obverse" />
      {% else %}
        <div class="placeholder"></div>
      {% endif %}

      {% if detailView.obverseText %}
        <figcaption class="token-image-caption">
          <strong>Obverse:</strong> {{ detailView.obverseText }}{% if token.counterstamp %} ({{ token.counterstamp }} Counterstamp){% endif %}
        </figcaption>
      {% endif %}
    </figure>

    <figure class="token-image-card">
      {% if token | hasTokenImage("r") %}
        <img
          class="token-image"
          src="{{ token | tokenImagePath('r') }}"
          alt="{{ detailView.tokenId }} reverse" />
      {% else %}
        <div class="placeholder"></div>
      {% endif %}

      {% if detailView.reverseText %}
        <figcaption class="token-image-caption">
          <strong>Reverse:</strong> {{ detailView.reverseText }}
        </figcaption>
      {% endif %}
    </figure>
  </div>

  <div class="token-lower-grid">
    <section class="section token-quickfacts">
      <h2>Quick Facts</h2>

      <div class="facts quickfacts-panel">
        <dl>
          {% for fact in detailView.quickFacts %}
            {% if fact.label == "Borough" and token.counterstamp %}
              <div class="facts-row">
                <dt>Counterstamp</dt>
                <dd>{{ token.counterstamp }}</dd>
              </div>
            {% endif %}

            <div class="facts-row">
              <dt>{{ fact.label }}</dt>
              <dd>{{ fact.value }}</dd>
            </div>
          {% endfor %}

          {% if token.maker %}
            <div class="facts-row">
              <dt>Maker</dt>
              <dd>{{ token.maker }}</dd>
            </div>
          {% endif %}

          {% if token.issued %}
            <div class="facts-row">
              <dt>Issued</dt>
              <dd>{{ token.issued | formatDateUS }}</dd>
            </div>
          {% endif %}

          {% if token.mintage %}
            <div class="facts-row">
              <dt>Mintage</dt>
              <dd>{{ token.mintage | formatNumber }}</dd>
            </div>
          {% endif %}

          {% if token.usage %}
            <div class="facts-row">
              <dt>Usage</dt>
              <dd>{{ token.usage }}</dd>
            </div>
          {% endif %}
        </dl>
      </div>
    </section>

    {% if detailView.notes %}
      <section class="section token-notes-section">
        <h2>Notes</h2>

        <div class="notes-frame js-notes-frame">
          <div class="notes-content js-notes-content">
            <p>{{ detailView.notes }}</p>

            {% if token.wanted %}
              <div class="wanted-note">
                <div class="wanted-note-label">Collector Interest</div>
                <div class="wanted-note-text">
                  {{ token.wantedNote or "I am interested in adding or upgrading this token in my collection." }}
                </div>
                <a class="wanted-note-link" href="/about/#want-list">Have one for sale? Contact me.</a>
              </div>
            {% endif %}
          </div>

          <button
            type="button"
            class="notes-more js-notes-more"
            hidden
            aria-expanded="false">
            Read more
          </button>
        </div>
      </section>
    {% endif %}
  </div>

  {% if detailView.pager and (detailView.pager.prev or detailView.pager.next) %}
  <nav class="token-pager" aria-label="Token navigation">
    <div class="token-pager-grid">
      {% if detailView.pager.prev %}
        <div class="token-pager-item token-pager-prev">
          <a class="token-pager-link" href="{{ detailView.pager.prev.url }}">
            <div class="token-pager-media">
              {% if prevToken and (prevToken | hasTokenImage("o")) %}
                <img
                  class="token-pager-image"
                  src="{{ prevToken | tokenImagePath('o') }}"
                  alt="{{ detailView.pager.prev.id }} obverse" />
              {% else %}
                <div class="token-pager-placeholder"></div>
              {% endif %}
            </div>

            <div class="token-pager-content">
              <span class="token-pager-label">← Previous</span>
              <strong>{{ detailView.pager.prev.id }}</strong>
              <span>{{ detailView.pager.prev.title }}</span>
            </div>
          </a>
        </div>
      {% endif %}

      {% if detailView.pager.next %}
        <div class="token-pager-item token-pager-next">
          <a class="token-pager-link" href="{{ detailView.pager.next.url }}">
            <div class="token-pager-media">
              {% if nextToken and (nextToken | hasTokenImage("o")) %}
                <img
                  class="token-pager-image"
                  src="{{ nextToken | tokenImagePath('o') }}"
                  alt="{{ detailView.pager.next.id }} obverse" />
              {% else %}
                <div class="token-pager-placeholder"></div>
              {% endif %}
            </div>

            <div class="token-pager-content">
              <span class="token-pager-label">Next →</span>
              <strong>{{ detailView.pager.next.id }}</strong>
              <span>{{ detailView.pager.next.title }}</span>
            </div>
          </a>
        </div>
      {% endif %}
    </div>
  </nav>
{% endif %}

  <script>
    (function () {
      function setupNotes() {
        const grids = document.querySelectorAll(".token-lower-grid");

        grids.forEach((grid) => {
          const quickFactsSection = grid.querySelector(".token-quickfacts");
          const notesSection = grid.querySelector(".token-notes-section");
          const notesFrame = grid.querySelector(".js-notes-frame");
          const notesContent = grid.querySelector(".js-notes-content");
          const notesMore = grid.querySelector(".js-notes-more");

          if (!quickFactsSection || !notesSection || !notesFrame || !notesContent || !notesMore) {
            return;
          }

          notesSection.style.minHeight = "";
          notesFrame.style.height = "";
          notesFrame.classList.remove("is-collapsed", "is-expanded");
          notesMore.hidden = true;
          notesMore.setAttribute("aria-expanded", "false");
          notesMore.textContent = "Read more";

          const heading = notesSection.querySelector("h2");
          const headingHeight = heading ? heading.offsetHeight + 14 : 48;

          const isMobile = window.matchMedia("(max-width: 700px)").matches;

          if (isMobile) {
            notesFrame.classList.add("is-expanded");
            notesFrame.classList.remove("is-collapsed");
            notesMore.hidden = true;
            notesFrame.style.height = "auto";
            notesSection.style.minHeight = "";
            return;
          }

          const quickFactsHeight = quickFactsSection.offsetHeight;
          if (!quickFactsHeight) return;

          const frameHeight = Math.max(140, quickFactsHeight - headingHeight - 42);

          notesSection.style.minHeight = quickFactsHeight + "px";
          notesFrame.style.height = frameHeight + "px";

          const needsToggle = notesContent.scrollHeight > notesFrame.clientHeight + 2;

          if (needsToggle) {
            notesFrame.classList.add("is-collapsed");
            notesMore.hidden = false;
          } else {
            notesFrame.classList.add("is-expanded");
          }

          notesMore.onclick = function () {
            const isExpanded = notesFrame.classList.contains("is-expanded");

            if (isExpanded) {
              notesFrame.classList.remove("is-expanded");
              notesFrame.classList.add("is-collapsed");
              notesFrame.style.height = frameHeight + "px";
              notesMore.textContent = "Read more";
              notesMore.setAttribute("aria-expanded", "false");
            } else {
              notesFrame.classList.remove("is-collapsed");
              notesFrame.classList.add("is-expanded");
              notesFrame.style.height = (notesContent.scrollHeight + 8) + "px";
              notesMore.textContent = "Show less";
              notesMore.setAttribute("aria-expanded", "true");
            }
          };
        });
      }

      window.addEventListener("load", setupNotes);
      window.addEventListener("resize", setupNotes);
    })();
  </script>
</section>
