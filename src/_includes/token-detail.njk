{% set detailSectionTitle = detailSectionTitle or "Tokens" %}
{% set detailSectionUrl = detailSectionUrl or "/" %}
{% set detailView = detailView or tokenDetailView or display %}

<section class="token-shell">
  <nav class="breadcrumb" aria-label="Breadcrumb">
    {% for crumb in detailView.breadcrumbItems %}
      {% if crumb.url %}
        <a href="{{ crumb.url }}">{{ crumb.label }}</a>
        {% if not loop.last %}<span>/</span>{% endif %}
      {% else %}
        <span aria-current="page">{{ crumb.label }}</span>
      {% endif %}
    {% endfor %}
  </nav>

  <h1>{{ detailView.tokenId }}</h1>

  <p class="token-subtitle">{{ detailView.tokenTitle }}</p>

  {% if detailView.metaParts and detailView.metaParts.length %}
    <p class="token-meta-line">{{ detailView.metaParts | join(" · ") }}</p>
  {% endif %}

  {% if detailView.badges and detailView.badges.length %}
    <div class="badges">
      {% for badge in detailView.badges %}
        <span class="badge">{{ badge }}</span>
      {% endfor %}
    </div>
  {% endif %}

  {% if token.desc %}
    <div class="token-summary">
      <p>{{ token.desc }}</p>
    </div>
  {% endif %}

  <div class="token-images">
    <figure class="token-image-card">
      {% if token | hasTokenImage("o") %}
        <img
          class="token-image"
          src="{{ token | tokenImagePath('o') }}"
          alt="{{ detailView.tokenId }} obverse" />
      {% else %}
        <div class="placeholder"></div>
      {% endif %}

      {% if detailView.obverseText %}
        <figcaption class="token-image-caption">
          <strong>Obverse:</strong> {{ detailView.obverseText }}
        </figcaption>
      {% endif %}
    </figure>

    <figure class="token-image-card">
      {% if token | hasTokenImage("r") %}
        <img
          class="token-image"
          src="{{ token | tokenImagePath('r') }}"
          alt="{{ detailView.tokenId }} reverse" />
      {% else %}
        <div class="placeholder"></div>
      {% endif %}

      {% if detailView.reverseText %}
        <figcaption class="token-image-caption">
          <strong>Reverse:</strong> {{ detailView.reverseText }}
        </figcaption>
      {% endif %}
    </figure>
  </div>

  <div class="token-lower-grid">
    <section class="section token-quickfacts">
      <h2>Quick Facts</h2>

      <div class="facts quickfacts-panel">
        <dl>
          {% for fact in detailView.quickFacts %}
            <div class="facts-row">
              <dt>{{ fact.label }}</dt>
              <dd>{{ fact.value }}</dd>
            </div>
          {% endfor %}
        </dl>
      </div>
    </section>

    {% if detailView.notes %}
      <section class="section token-notes-section">
        <h2>Notes</h2>

        <div class="notes-frame js-notes-frame">
          <div class="notes-content js-notes-content">
            <p>{{ detailView.notes }}</p>

            {% if token.wanted %}
              <div class="wanted-note">
                <div class="wanted-note-label">Collector Interest</div>
                <div class="wanted-note-text">
                  {{ detailView.wantedNote }}
                </div>
                <a class="wanted-note-link" href="/about/#want-list">Have one for sale? Contact me.</a>
              </div>
            {% endif %}
          </div>

          <button
            type="button"
            class="notes-more js-notes-more"
            hidden
            aria-expanded="false">
            Read more
          </button>
        </div>
      </section>
    {% endif %}
  </div>

  {% if detailView.pager and (detailView.pager.prev or detailView.pager.next) %}
  <nav class="token-pager" aria-label="Token navigation">
    <div class="token-pager-grid">
      {% if detailView.pager.prev %}
        <div class="token-pager-item token-pager-prev">
          <a class="token-pager-link" href="{{ detailView.pager.prev.url }}"{% if prevToken %} data-prev-obverse="{{ prevToken | tokenImagePath('o') }}" data-prev-reverse="{{ prevToken | tokenImagePath('r') }}"{% endif %}>
            <div class="token-pager-media">
              {% if prevToken and (prevToken | hasTokenThumb("o")) %}
                <img
                  class="token-pager-image"
                  src="{{ prevToken | tokenThumbPath('o') }}"
                  alt="{{ detailView.pager.prev.id }} obverse" />
              {% else %}
                <div class="token-pager-placeholder"></div>
              {% endif %}
            </div>

            <div class="token-pager-content">
              <span class="token-pager-label">← Previous</span>
              <strong>{{ detailView.pager.prev.id }}</strong>
              <span>{{ detailView.pager.prev.title }}</span>
            </div>
          </a>
        </div>
      {% endif %}

      {% if detailView.pager.next %}
        <div class="token-pager-item token-pager-next">
          <a class="token-pager-link" href="{{ detailView.pager.next.url }}"{% if nextToken %} data-next-obverse="{{ nextToken | tokenImagePath('o') }}" data-next-reverse="{{ nextToken | tokenImagePath('r') }}"{% endif %}>
            <div class="token-pager-media">
              {% if nextToken and (nextToken | hasTokenThumb("o")) %}
                <img
                  class="token-pager-image"
                  src="{{ nextToken | tokenThumbPath('o') }}"
                  alt="{{ detailView.pager.next.id }} obverse" />
              {% else %}
                <div class="token-pager-placeholder"></div>
              {% endif %}
            </div>

            <div class="token-pager-content">
              <span class="token-pager-label">Next →</span>
              <strong>{{ detailView.pager.next.id }}</strong>
              <span>{{ detailView.pager.next.title }}</span>
            </div>
          </a>
        </div>
      {% endif %}
    </div>
  </nav>
{% endif %}

  <div id="image-modal" class="image-modal" style="display: none;">
    <div class="image-modal-content">
      <img id="modal-image" src="" alt="">
      <button class="image-modal-close">&times;</button>
    </div>
  </div>

  <script src="/assets/js/token-detail.js" defer></script>
</section>
