---
layout: base.njk
pagination:
  data: siteSections
  size: 1
  alias: siteSection
permalink: "/{{ siteSection.key }}/index.html"
eleventyComputed:
  title: "{{ siteSection.title }}"
---

<section class="section">
  <nav class="breadcrumb" aria-label="Breadcrumb">
    <a href="/">Home</a>
    <span>/</span>
    <span>{{ siteSection.title }}</span>
  </nav>

  <h1>{{ siteSection.title }}</h1>

  {% if siteSection.intro %}
    <p class="section-intro">{{ siteSection.intro }}</p>
  {% endif %}

  <div class="home-section-grid">
    {% for group in groups | sort(attribute="order") %}
      {% if group.section == siteSection.key %}
        <a class="card-link" href="{{ group.url }}">
          <article class="card home-section-card">
            <div class="home-section-card-layout">
              <div class="home-section-card-body">
                <strong class="home-section-card-title">{{ group.title }}</strong>
                <p class="home-section-card-desc">{{ group.description }}</p>
              </div>

              {% if group.cardImage %}
                <div class="home-section-card-media">
                  <img
                    class="home-section-card-image"
                    src="{{ group.cardImage }}"
                    alt="{{ group.title }}" />
                </div>
              {% endif %}
            </div>
          </article>
        </a>
      {% endif %}
    {% endfor %}
  </div>
</section>
