---
layout: base.njk
title: Listed Tokens
permalink: /listed/index.html
---
<section class="section">
  <h1>Listed Tokens</h1>
  <p class="section-intro">
    Browse listed New York City transportation-related tokens by borough and listed special groups.
  </p>

  <div class="grid-4">
    {% for group in groups | sort(attribute="order") %}
      {% if group.section == "listed" %}
      <a class="card-link" href="{{ group.url }}">
        <article class="card">
          <strong>{{ group.title }}</strong>
          <p>{{ group.description }}</p>
        </article>
      </a>
      {% endif %}
    {% endfor %}
  </div>
</section>
