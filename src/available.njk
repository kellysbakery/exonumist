---
layout: base.njk
title: Available
description: Duplicate transportation tokens available for sale or trade, organized by state and catalog number.
permalink: /available/index.html
---

<section class="section">
  <nav class="breadcrumb" aria-label="Breadcrumb">
    <a href="/">Home</a>
    <span>/</span>
    <span>Available</span>
  </nav>
  <h1>Available</h1>

  <p class="section-intro">
    Duplicate transportation tokens from my collection are available for sale or trade.
  </p>

  <p class="for-sale-terms">
    Please contact me to confirm current availability. Prices are based on catalog value unless
    otherwise noted.
  </p>

  <div class="available-mode-switch" aria-label="Available token search mode">
    <button
      class="available-mode-button is-active"
      type="button"
      data-available-mode-button="search"
      aria-pressed="true">
      Search one token
    </button>
    <button
      class="available-mode-button"
      type="button"
      data-available-mode-button="want"
      aria-pressed="false">
      Match a want list
    </button>
  </div>

  <p class="section-intro">
    <strong>{{ forSale.total }}</strong> tokens available.
    Last updated: {{ forSaleMeta.lastUpdated }}
  </p>

  <div class="available-workflow" data-available-panel="search">
    <h2>Find a token</h2>
    <p class="section-intro">
      Search by catalog number to check whether I have a duplicate available.
    </p>

    <div class="for-sale-search">
      <label for="for-sale-search-input">Search catalog number</label>
      <input
        id="for-sale-search-input"
        type="search"
        placeholder="Search, e.g. NY905A, AL120..."
        autocomplete="off" />
    </div>
  </div>

  <div class="available-workflow" data-available-panel="want" hidden>
    <h2>Match a want list</h2>
    <p class="section-intro">
      Paste the catalog numbers you're looking for, then match them against my available duplicates.
    </p>

    <div class="want-list">
      <label class="want-list-label" for="want-list-input">Want List</label>
      <p class="want-list-help">
        One catalog number per line works best. Comma-separated lists are okay too.
      </p>
      <p class="want-list-help want-list-example">
        Example:<br />
        AK50A<br />
        AR300F<br />
        NY905A
      </p>
      <textarea
        class="want-list-input"
        id="want-list-input"
        data-want-list-input
        rows="5"
        placeholder="Paste your want list here..."></textarea>

      <div class="want-list-actions">
        <button class="btn" type="button" data-want-list-match>Match Want List</button>
        <button class="btn" type="button" data-want-list-clear>Clear Want List</button>
      </div>

      <p class="want-list-result" data-want-list-result aria-live="polite"></p>
    </div>
  </div>

  <p class="section-intro for-sale-results-summary">
    <strong id="for-sale-visible-count">{{ forSale.total }}</strong>
    of
    <strong>{{ forSale.total }}</strong>
    tokens shown.
  </p>

  <div class="for-sale-list">
    {% for group in forSale.groups %}
      <details class="for-sale-group" data-sale-group data-count="{{ group.items.length }}">
        <summary>
          {{ group.stateName }}
          <span>
            (<span data-group-visible-count>{{ group.items.length }}</span>)
          </span>
        </summary>

        <div class="for-sale-items">
          {% for item in group.items %}
            <div
              class="for-sale-item"
              data-sale-item
              data-search-text="{{ item.searchText }}"
              data-catalog-id="{{ item.catalogId }}"
              data-catalog-value="{{ item.value }}"
              data-group-name="{{ group.stateName }}">
              <span class="for-sale-id">{{ item.catalogId }}</span>
              <span class="for-sale-price">Price: {{ item.value }}</span>
              <button
                class="inquiry-toggle"
                type="button"
                data-inquiry-toggle
                aria-pressed="false"
                aria-label="Add {{ item.catalogId }} to inquiry list">
                Add
              </button>
            </div>
          {% endfor %}
        </div>
      </details>
    {% endfor %}
  </div>

  <p class="for-sale-empty" id="for-sale-empty" hidden>
    No matching tokens found.
  </p>
</section>

<div class="inquiry-bar" data-inquiry-bar hidden>
  <div>
    <span class="inquiry-count" data-inquiry-bar-count>0 tokens selected</span>
    <p class="inquiry-warning" data-inquiry-warning hidden>
      Please limit your inquiry list to 50 tokens or fewer before sending an email.
    </p>
  </div>
  <div class="inquiry-actions">
    <button class="btn primary" type="button" data-inquiry-bar-email disabled>Email Inquiry</button>
    <button class="btn" type="button" data-inquiry-bar-clear disabled>Clear List</button>
  </div>
</div>

<script src="/assets/js/for-sale.js"></script>
<script src="/assets/js/for-sale-inquiry.js"></script>
