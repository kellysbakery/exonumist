---
layout: base.njk
title: Architecture Test
permalink: /architecture-test/index.html
---

<section class="section">
  <h1>Architecture Test</h1>

  {% for siteSection in siteSections %}
    <section class="section">
      <h2>{{ siteSection.title }}</h2>

      <div class="grid-3">
        {% for group in groups %}
          {% if group.section == siteSection.key %}
            <article class="card">
              <strong>{{ group.title }}</strong>
              <p>Group key: {{ group.key }}</p>
            </article>
          {% endif %}
        {% endfor %}
      </div>
    </section>
  {% endfor %}
</section>