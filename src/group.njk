---
layout: base.njk
pagination:
  data: sections
  size: 1
  alias: section
permalink: "/listed/{{ section.sec }}/index.html"
eleventyComputed:
  title: "{{ section.title }} – Listed Tokens"
---
{% if section.pub %}
<section class="section">
  <div class="meta breadcrumb">
    <a href="/">Home</a>
    <span>/</span>
    <a href="/listed/">Listed Tokens</a>
    <span>/</span>
    <span aria-current="page">{{ section.title }}</span>
  </div>

  <h1>{{ section.title }}</h1>

  <p class="section-intro">
    Listed {{ section.borough }} transportation tokens from the {{ site.catalog.shortName }}.
  </p>

  <div class="grid-3 token-card-grid">
    {% for token in collections.officialAll %}
      {% if token.sec == section.sec and token.pub %}
      <a class="card-link" href="/official/{{ token.displayId | lower }}/">
        <article class="card token-list-card">

          <div class="token-list-card-media">
            {% if token | hasOfficialImage("o") %}
              <img
                class="token-list-card-image"
                src="{{ token | officialImagePath('o') }}"
                alt="{{ token.displayId }} obverse" />
            {% else %}
              <div class="token-list-card-placeholder"></div>
            {% endif %}
          </div>

          <div class="token-list-card-body">
            <span class="eyebrow">{{ token.displayId }}</span>

            <strong class="token-list-card-title">
              {{ token.title }}
            </strong>

            {% if token.desc %}
              <p class="token-list-card-desc">
                {{ token.desc }}
              </p>
            {% endif %}

            <p class="token-list-card-meta">
              {% if token.mat %}
                {{ token.mat | lookup(lookups.materials) }}
              {% endif %}
              {% if token.size %}
                · {{ token.size }} mm
              {% endif %}
              {% if token.val is not none %}
                · ${{ token.val | money }}
              {% endif %}
            </p>
          </div>

        </article>
      </a>
      {% endif %}
    {% endfor %}
  </div>
</section>
{% endif %}